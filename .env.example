# Copy this file to .env and fill in values for your environment.
# .env is git-ignored by default.

# Generic app/network settings
APP_USER_AGENT=afl-predictions-bot/0.1 (+https://github.com/your-org/afl)
SQUIGGLE_USER_AGENT=AFL-Predictions/1.0 (Educational ML project; contact: your-email@example.com)
DB_URL=sqlite:///data/processed/afl.db

# Optional API key for scripts/collect_odds.py (The Odds API)
THE_ODDS_API_KEY=
